{
  "expo": {
    "name": "Invyte",
    "slug": "invyte",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-invyte.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1062",
        "foregroundImage": "./assets/images/icon-invyte.png",
        "backgroundImage": "./assets/images/icon-invyte.png",
        "monochromeImage": "./assets/images/icon-invyte.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.invyte"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1062",
          "android": {
            "image": "./assets/images/icon-invyte.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#9333ea",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Invyte to use your camera to scan RSVP QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
